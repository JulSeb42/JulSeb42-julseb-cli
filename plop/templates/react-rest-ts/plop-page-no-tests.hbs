/*=============================================== Generate page ===============================================*/

const { toTitleCase, toKebabCase } = require("ts-utils-julseb")
const { generatePageRoute } = require("../utils/generate-page-route")

const generatePage = (/** @type {import('plop').NodePlopAPI} */ plop) => {
    const { setGenerator } = plop

    setGenerator("page", {
        description: "Generate page",
        prompts: [
            {
                type: "input",
                name: "name",
                message: "Enter page's name",
                validate: data => {
                    if (!data) return "Name is required"
                    return true
                },
            },
            {
                type: "input",
                name: "title",
                message: "Enter page title",
                default: data => toTitleCase(data?.name || ""),
            },
            {
                type: "input",
                name: "path",
                message: "Enter path",
                default: data => `/${toKebabCase(data?.name || "")}`,
            },
            {
                type: "confirm",
                name: "multi",
                message: "Is this a multi file page?",
                default: false,
            },
            {
                type: "list",
                name: "protected",
                choices: ["none", "protected", "anon"],
                default: "none",
            },
        ],

        actions: data => {
            const actions = [
                {
                    type: "add",
                    path: data.multi
                        ? "../client/src/pages/{{surroundBrackets "pascalCase name" }}/{{surroundBrackets "pascalCase name" }}.tsx"
                        : "../client/src/pages/{{surroundBrackets "pascalCase name" }}.tsx",
                    templateFile: "./templates/page/page-file.hbs",
                },
                {
                    type: "modify",
                    path: "../client/src/routes/routes.tsx",
                    template:
                        'import { {{surroundBrackets "pascalCase name" }} } from "pages/{{surroundBrackets "pascalCase name" }}"\n$1',
                    pattern: /(\/\/ prependImport)/g,
                },
                {
                    type: "modify",
                    path: "../client/src/routes/routes.tsx",
                    template: generatePageRoute(data.protected),
                    pattern: /(\/\/ prependRoute)/g,
                },
                {
                    type: "modify",
                    path: "../client/src/routes/paths.ts",
                    template:
                        '{{surroundBrackets "constantCase name" }}: "/{{surroundBrackets "kebabCase path" }}",\n$1',
                    pattern: /(\/\/ prependPath)/g,
                },
            ]

            if (data.multi) {
                actions.push({
                    type: "add",
                    path: "../client/src/pages/{{surroundBrackets "pascalCase name" }}/index.ts",
                    templateFile: "./templates/page/page-index.hbs",
                })
            }

            return actions
        },
    })
}

module.exports = { generatePage }
