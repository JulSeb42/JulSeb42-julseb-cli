{
    "name": "@julseb-lib/julseb-cli",
    "version": "0.0.0",
    "description": "Repository with all the boilerplates generated by `julseb-cli`.",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "clean:plop": "rm -rf plop/scripts",
        "build:plop": "yarn clean:plop && tsc --p plop/tsconfig.json",
        "plop": "yarn build:plop && npx ."
    },
    "author": "Julien Sebag",
    "license": "MIT",
    "devDependencies": {
        "plop": "^4.0.1",
        "typescript": "^5.5.4"
    },
    "dependencies": {
        "ts-utils-julseb": "^2.4.5"
    },
    "bin": {
        "@julseb-lib/julseb-cli": "index.js"
    },
    "resolutions": {
        "inquirer": "9.3.5"
    },
    "overrides": {
        "node-plop": {
            "inquirer": "9.3.5"
        }
    },
    "peerDependencies": {
        "inquirer": "9.3.5"
    }
}
