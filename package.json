{
    "name": "@julseb-lib/julseb-cli",
    "version": "0.0.36",
    "description": "Repository with all the boilerplates generated by `julseb-cli`.",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "clean:plop": "rm -rf scripts",
        "build:plop": "npm run clean:plop && tsc --p tsconfig.json",
        "plop": "rm -rf hello-world && npm run build:plop && npx ."
    },
    "author": "Julien Sebag",
    "license": "MIT",
    "devDependencies": {
        "child_process": "^1.0.2",
        "plop": "^4.0.1",
        "typescript": "^5.6.2"
    },
    "dependencies": {
        "@julseb-lib/utils": "^0.0.2"
    },
    "bin": {
        "julseb-cli": "index.js"
    },
    "resolutions": {
        "inquirer": "9.3.5"
    },
    "overrides": {
        "node-plop": {
            "inquirer": "9.3.5"
        }
    },
    "peerDependencies": {
        "inquirer": "9.3.5"
    }
}
