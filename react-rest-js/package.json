{
    "name": "react-rest-js",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "start": "node server.js",
        "build": "cd client && yarn build",
        "install": "cd client && yarn",
        "server": "nodemon server/index.js",
        "client": "cd client && yarn dev",
        "dev": "concurrently --kill-others 'yarn server' 'yarn client'",
        "plop": "plop --plopfile 'plop/src/plopfile.mjs'",
        "plop:c": "yarn plop component",
        "plop:sc": "yarn plop single-component",
        "plop:p": "yarn plop page",
        "plop:r": "yarn plop route",
        "plop:m": "yarn plop model"
    },
    "dependencies": {
        "@julseb-lib/utils": "^0.0.2",
        "bcryptjs": "^2.4.3",
        "cloudinary": "^2.5.0",
        "concurrently": "^9.0.1",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.0",
        "express-jwt": "^8.4.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.7.0",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "multer-storage-cloudinary": "^4.0.0",
        "nodemailer": "^6.9.15"
    },
    "devDependencies": {
        "nodemon": "^3.1.7",
        "plop": "^4.0.1"
    }
}
